<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NetworkAnalyzer.ViewModels"
        x:Class="NetworkAnalyzer.Views.MainWindow"
        Title="Network Analyzer"
        Width="1100" Height="750"
        x:DataType="vm:MainWindowViewModel">
    
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- Основной фон окна - черный -->
    <Window.Background>
        <SolidColorBrush Color="#000000"/>
    </Window.Background>

    <Window.Styles>
        <!-- Стиль для выделенных элементов в ListBox -->
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Стиль для обычных элементов -->
        <Style Selector="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <!-- Стиль для кнопок -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- Стиль для текстовых полей -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Стиль для Border (рамок) -->
        <Style Selector="Border">
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
        
        <!-- Стиль для TextBlock -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Заголовок -->
        <Border Padding="15" Background="#1a1a1a" BorderBrush="#404040" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Анализатор сетевых подключений" 
                          FontSize="22" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Network Analyzer v1.0" 
                          FontSize="12" 
                          Foreground="#808080"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основная панель с разделением -->
        <Grid Grid.Row="1" ColumnDefinitions="2*, 3*" Margin="15">
            <!-- Левая панель: сетевые интерфейсы -->
            <DockPanel Margin="5">
                <TextBlock Text="🌐 Сетевые интерфейсы" 
                          FontSize="18" 
                          FontWeight="Bold" 
                          Margin="0,0,0,15" 
                          DockPanel.Dock="Top"/>
                
                <!-- Список интерфейсов -->
                <ListBox ItemsSource="{Binding NetworkInterfaces}"
                         SelectedItem="{Binding SelectedInterface}"
                         Height="220"
                         BorderBrush="#404040"
                         BorderThickness="1"
                         CornerRadius="5"
                         Background="#1a1a1a"
                         DockPanel.Dock="Top">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🔌" FontSize="14"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Status}" Foreground="#808080"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Информация о выбранном интерфейсе -->
                <Border BorderBrush="#404040" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,15"
                        Background="#1a1a1a"
                        DockPanel.Dock="Top">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                        <StackPanel Spacing="8">
                            <TextBlock Text="📋 Детальная информация" 
                                      FontSize="16" 
                                      FontWeight="Bold" 
                                      Margin="0,0,0,10"/>
                            
                            <Border Padding="10" Background="#0d0d0d" CornerRadius="5" BorderBrush="#404040" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Описание:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.Description}" TextWrapping="Wrap" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="IP-адрес:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.IpAddress}" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Маска подсети:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.SubnetMask}" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="MAC-адрес:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.MacAddress}" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Состояние:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.Status}" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Скорость:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.Speed}" Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Тип:" FontWeight="Bold" Foreground="#808080" MinWidth="100" Grid.Column="0"/>
                                        <TextBlock Text="{Binding SelectedInterface.InterfaceType}" Grid.Column="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <!-- Правая панель: анализ URL -->
            <DockPanel Grid.Column="1" Margin="5">
                <TextBlock Text="🔍 Анализ URL" 
                          FontSize="18" 
                          FontWeight="Bold" 
                          Margin="0,0,0,15" 
                          DockPanel.Dock="Top"/>
                
                <!-- Поле ввода -->
                <Border BorderBrush="#404040" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="10" 
                        Margin="0,0,0,15"
                        Background="#1a1a1a"
                        DockPanel.Dock="Top">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Text="{Binding InputUrl}" 
                                 Watermark="Введите URL (например, google.com)" 
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Grid.Column="0"/>
                        <Button Command="{Binding AnalyzeUrlCommand}" 
                                Content="Анализировать"
                                Padding="20,8"
                                Background="#2d2d2d"
                                BorderBrush="#404040"
                                BorderThickness="1"
                                CornerRadius="5"
                                Grid.Column="1"/>
                    </Grid>
                </Border>

                <!-- Результаты анализа с переносом длинного текста -->
                <Border BorderBrush="#404040" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,15"
                        Background="#1a1a1a"
                        DockPanel.Dock="Top">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <StackPanel Spacing="8">
                            <TextBlock Text="📊 Результаты анализа" 
                                      FontSize="16" 
                                      FontWeight="Bold" 
                                      Margin="0,0,0,10"/>
                            
                            <Border Padding="10" Background="#0d0d0d" CornerRadius="5" BorderBrush="#404040" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <!-- Схема -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Схема:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Scheme, FallbackValue='—'}" Grid.Column="1"/>
                                    </Grid>
                                    
                                    <!-- Хост -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Хост:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Host, FallbackValue='—'}" Grid.Column="1"/>
                                    </Grid>
                                    
                                    <!-- Порт -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Порт:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Port, FallbackValue='—'}" Grid.Column="1"/>
                                    </Grid>
                                    
                                    <!-- Путь (с переносом) -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Путь:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Path, FallbackValue='—'}" 
                                                   Grid.Column="1" 
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                    
                                    <!-- Параметры запроса (с переносом) -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Параметры:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Query, FallbackValue='—'}" 
                                                   Grid.Column="1" 
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                    
                                    <!-- Фрагмент (с переносом) -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Фрагмент:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.Fragment, FallbackValue='—'}" 
                                                   Grid.Column="1" 
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                    
                                    <!-- Тип адреса -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Тип:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.AddressType, FallbackValue='—'}" Grid.Column="1"/>
                                    </Grid>
                                    
                                    <!-- DNS (с переносом) -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="DNS:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.DnsInfo, FallbackValue='—'}" 
                                                   TextWrapping="Wrap" 
                                                   Grid.Column="1"/>
                                    </Grid>
                                    
                                    <!-- Ping -->
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Ping:" FontWeight="Bold" Foreground="#808080" MinWidth="70" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CurrentAnalysis.PingReply, FallbackValue='—'}" Grid.Column="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- История -->
                <TextBlock Text="📜 История проверок" 
                          FontSize="16" 
                          FontWeight="Bold" 
                          Margin="0,5,0,10"
                          DockPanel.Dock="Top"/>
                
                <ListBox x:Name="HistoryList"
                        ItemsSource="{Binding History}" 
                        Height="150"
                        BorderBrush="#404040"
                        BorderThickness="1"
                        CornerRadius="5"
                        Background="#1a1a1a"
                        DockPanel.Dock="Top">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" 
                                    Margin="2" 
                                    CornerRadius="3"
                                    Background="#0d0d0d"
                                    BorderBrush="#404040"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <!-- Простой индикатор без конвертера -->
                                        <Border Width="10" 
                                                Height="10" 
                                                CornerRadius="5"
                                                Background="Gray"
                                                Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                                                  FontWeight="Light"
                                                  Foreground="#808080"
                                                  FontSize="11"/>
                                        <TextBlock Text="{Binding OriginalUrl}" 
                                                  FontWeight="Medium"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Host}" 
                                              FontStyle="Italic"
                                              Foreground="#808080"
                                              FontSize="11"
                                              Margin="15,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Кнопка загрузки -->
                <Button Content="Загрузить выбранный URL"
                        Command="{Binding LoadFromHistoryCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=HistoryList}"
                        Margin="0,10,0,0"
                        Padding="10,5"
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Top"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>